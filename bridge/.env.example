# Bridge configuration template. Copy to PROJECT_ROOT/.telegram_bot/.env and fill in.
# The project .env wins; this package-level .env is a fallback for shared values
# (e.g. CLAUDE_CLI_PATH). Do NOT commit real tokens.

# --- Required ---
TELEGRAM_BOT_TOKEN=your_bot_token_here

# --- Access control (comma-separated Telegram user IDs; empty = allow all) ---
ALLOWED_USER_IDS=

# --- Claude CLI (optional; defaults to PATH lookup) ---
# CLAUDE_CLI_PATH=/opt/homebrew/bin/claude

# --- Session / timeout knobs ---
# AUTO_NEW_SESSION_AFTER_HOURS=24        # 0/false/off disables
# CLAUDE_PROCESS_TIMEOUT=600             # per-turn timeout in seconds
# CLAUDE_AUTO_RESUME=0                   # 1 to silently auto-continue on timeout
# CLAUDE_AUTO_RESUME_MAX=2               # max silent auto-resume retries

# --- Streaming ---
# DRAFT_UPDATE_MIN_CHARS=30
# DRAFT_UPDATE_INTERVAL=1.0

# --- Voice input (local faster-whisper only; input only, no TTS) ---
# TRANSCRIPTION_PROVIDER=local
# LOCAL_WHISPER_MODEL=small
# WHISPER_LANGUAGE=ko                    # auto/empty = auto-detect
# VOICE_REPLY_ENABLED=false
# MAX_VOICE_DURATION=300
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# --- Logging ---
# LOG_LEVEL=INFO
