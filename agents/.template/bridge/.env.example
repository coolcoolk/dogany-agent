# Bridge configuration template. Copy to PROJECT_ROOT/.telegram_bot/.env and fill in.
# The project .env wins; this package-level .env is a fallback for shared values
# (e.g. CLAUDE_CLI_PATH). Do NOT commit real tokens.

# --- Required ---
TELEGRAM_BOT_TOKEN=your_bot_token_here

# --- Access control (comma-separated Telegram user IDs) ---
# Born-locked: when set, this list is authoritative and claim mode is off.
# Empty = claim mode (first /start caller claims the bot).
ALLOWED_USER_IDS=

# --- Localization (user-facing strings: ko or en; default en) ---
# LOCALE=en

# --- Claude CLI (optional; defaults to PATH lookup) ---
# CLAUDE_CLI_PATH=/opt/homebrew/bin/claude

# --- Session / timeout knobs ---
# AUTO_NEW_SESSION_AFTER_HOURS=24        # 0/false/off disables
# CLAUDE_PROCESS_TIMEOUT=600             # per-turn timeout in seconds
# CLAUDE_AUTO_RESUME=0                   # 1 to silently auto-continue on timeout
# CLAUDE_AUTO_RESUME_MAX=2               # max silent auto-resume retries

# --- Streaming ---
# DRAFT_UPDATE_MIN_CHARS=30
# DRAFT_UPDATE_INTERVAL=1.0

# --- Voice input (local faster-whisper only; input only, no TTS) ---
# TRANSCRIPTION_PROVIDER=local
# LOCAL_WHISPER_MODEL=small
# WHISPER_LANGUAGE=ko                    # auto/empty = auto-detect
# VOICE_REPLY_ENABLED=false
# MAX_VOICE_DURATION=300
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# --- Email (dogany-mailer service; optional, connect-time) ---
# Fill to enable outbound email. Leave blank = email stays "not connected".
# Gmail: use an App Password (not your login password). Never commit real values.
# EMAIL_ADDRESS=            # sender / SMTP login (e.g. you@gmail.com)
# EMAIL_APP_PASSWORD=       # app password; never logged
# EMAIL_CC=                 # your address, auto-CC'd on every send
# SMTP_HOST=smtp.gmail.com  # optional, default smtp.gmail.com
# SMTP_PORT=587             # optional, default 587 (STARTTLS)

# --- Path guard extra roots ---
# Extra absolute roots (os.pathsep-separated) the path guard treats as inside PROJECT_ROOT; leave empty for strict default.
EXTRA_ALLOWED_ROOTS=

# --- Logging ---
# LOG_LEVEL=INFO
