{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "model": "sonnet",
  "autoMemoryEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "/usr/bin/python3 -c \"import sys,json,os; d=json.load(sys.stdin); w=d.get('workspace') or {}; p=w.get('project_dir') or w.get('current_dir') or os.getcwd(); print('dogany ' + os.path.basename(p.rstrip('/')))\""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill|Workflow",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 __PROJECT_ROOT__/routines/token-gate.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Skill|Workflow|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 __PROJECT_ROOT__/routines/usage-gate.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 __PROJECT_ROOT__/routines/cc-memory-write-guard.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 __PROJECT_ROOT__/routines/card-followup.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 __PROJECT_ROOT__/routines/session-recap.py"
          },
          {
            "type": "command",
            "command": "ONBOARDING_FILE=__PROJECT_ROOT__/AGENT.md /usr/bin/python3 __PROJECT_ROOT__/routines/onboarding-check.py"
          },
          {
            "type": "command",
            "command": "/usr/bin/python3 __PROJECT_ROOT__/routines/version-check.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 __PROJECT_ROOT__/memory-engine/memory.py hook",
            "timeout": 12
          }
        ]
      }
    ]
  }
}
