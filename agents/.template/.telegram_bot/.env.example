# .env.example -- MANUAL SETUP REFERENCE for agents/.template/.telegram_bot/.env
#
# This file documents the keys that the bridge reads. It is NOT consumed by
# mint.sh (which generates the .env from env_render). Use this as a reference
# if you are setting up an instance by hand rather than via the installer or
# `mint.sh --print-env`.
#
# Copy to .env and fill in your values.
# The bridge loads PROJECT_ROOT/.telegram_bot/.env first, then falls back to
# the package bridge/.env for shared defaults (CLAUDE_CLI_PATH, etc.).
# This instance .env only needs this agent's own bot token and any overrides.

TELEGRAM_BOT_TOKEN=<bot token from BotFather>

# ALLOWED_USER_IDS: Born-locked. When set, this list is authoritative and
# claim mode is off. Empty = claim mode (first /start caller claims the bot).
ALLOWED_USER_IDS=

# LOCALE: working language for the bridge (en or ko). Set by mint via --lang.
LOCALE=en

# TZ: IANA timezone string (e.g. Asia/Seoul). When unused, OMIT the line
# entirely (an empty TZ= is not the same as an absent one); mint does the same.
# TZ=

# EXTRA_ALLOWED_ROOTS: os.pathsep-separated path-guard roots. Empty for the product.
EXTRA_ALLOWED_ROOTS=

# --- Bridge model whitelist (controls /model picker in Telegram) ---
# Set by installer from subscription tier. max tier -> sonnet,opus,haiku; else sonnet,haiku.
# Override here if you want a different set after install.
# BRIDGE_MODELS=sonnet,haiku

# --- Voice input (faster-whisper). Model chosen during install. ---
# Omit to use config.py default ("small").
# LOCAL_WHISPER_MODEL=small

# --- Opt-in remote version check (session-start hook) ---
# Default OFF. Set to 1 to enable HTTPS fetch of VERSION from the public repo
# at session start. Sends ONLY a GET to raw.githubusercontent.com/coolcoolk/dogany-agent/main/VERSION.
# No user data, no auth token, no instance metadata is sent -- server sees only your IP,
# the same as a git clone. The check is 2-second-timeout and fail-silent (never blocks a session).
# DOGANY_VERSION_CHECK=1

# --- Email (dogany-mailer service; optional, connect-time) ---
# Fill to enable outbound email. Leave blank = email stays "not connected".
# Gmail: use an App Password (not your login password). Never commit real values.
# EMAIL_ADDRESS=            # sender / SMTP login (e.g. you@gmail.com)
# EMAIL_APP_PASSWORD=       # app password; never logged
# EMAIL_CC=                 # your address, auto-CC'd on every send
# SMTP_HOST=smtp.gmail.com  # optional, default smtp.gmail.com
# SMTP_PORT=587             # optional, default 587 (STARTTLS)
