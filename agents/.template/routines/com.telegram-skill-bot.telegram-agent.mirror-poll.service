[Unit]
# DGN-268 S3: Linux parity for the macOS mirror-poll plist (StartInterval 300).
# One-shot poll cycle fired every 300s by the paired .timer. Same flag-gate /
# unauth-throttle safety as the plist path -- the shell exits 0 silently when
# the mirror module is off/absent, and warns at most once/day when on-but-
# unauthed, so systemd never enters a crash-restart loop.
Description=dogany mirror poll (__AGENT_NAME__) -- GCal/GTasks 5-min sync cycle

[Service]
Type=oneshot
ExecStart=/bin/bash __PROJECT_ROOT__/routines/cron-guard.sh --label com.telegram-skill-bot.__AGENT_NAME__.mirror-poll --log __PROJECT_ROOT__/.telegram_bot/logs/mirror-poll.stdout.log -- /bin/bash __PROJECT_ROOT__/routines/mirror-poll.sh
WorkingDirectory=__PROJECT_ROOT__
Environment=HOME=__HOME__
Environment=PATH=__HOME__/.npm-global/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:__HOME__/.local/bin
