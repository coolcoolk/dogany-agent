# Copy to .env and fill. New bridge loads PROJECT_ROOT/.telegram_bot/.env first,
# then shared ../../.rules/.env (CLAUDE_CLI_PATH etc), then package bridge/.env.
# Per-agent .env only needs this agent's own bot token.
TELEGRAM_BOT_TOKEN=<bot token from BotFather>

# Optional per-agent overrides (otherwise inherited from .rules/.env):
# CLAUDE_CLI_PATH=$HOME/.npm-global/bin/claude
# ALLOWED_USER_IDS=
